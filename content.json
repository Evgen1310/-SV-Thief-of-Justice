{
    "Format": "2.8.0",
    "ConfigSchema": {
        "AfterClaireEvent": {
            "AllowValues": "true, false",
            "Default": "true",
            "AllowBlank": false,
            "Section": "Schedule"
        },
        //I tried to do multiple seasons but "AllowMultiple" produced "fall, Winter" instead of ["fall", "Winter"] so only the first season was applied :(.
        "ShowSeason": {
            "AllowValues": "spring, summer, fall, winter",
            "Default": "fall",
            "AllowBlank": false,
            "Section": "Schedule"
        }
    },
    "DynamicTokens": [
        {
            "Name": "showmovie",
            "Value": "false"
        },
        {
            "Name": "showmovie",
            "Value": "true",
            "When": {
                "AfterClaireEvent": false
            }
        },
        {
            "Name": "showmovie",
            "Value": "true",
            "When": {
                "AfterClaireEvent": true,
                "HasSeenEvent |contains=4269703": true
            }
        }
   ],
    "Changes": [
        // Load data
        // Poster
        {
            "Action": "Load",
            "Target": "{{ModId}}/poster",
            "FromFile": "assets/movie_poster.png"
        },
        // Tilesheet
        {
            "Action": "Load",
            "Target": "{{ModId}}/tilesheet",
            "FromFile": "assets/tilesheet_{{Language}}.png",
            "When": {
                "HasFile:assets/tilesheet_{{Language}}.png": true
            }
        },
        {
            "Action": "Load", 
            "Target": "{{ModId}}/tilesheet",
            "FromFile": "assets/tilesheet.png",
            "When": {
                "HasFile:assets/tilesheet_{{Language}}.png": false
            }
        },

        // Add poster to furnitures
        {
            "Action": "EditData",
            "Target": "Data/Furniture",
            "Entries": {
                "{{ModId}}_ClairePoster": "{{ModId}}_ClairePoster/painting/1 2/1 2/1/400/-1/{{i18n:Poster.Name}}/0/{{ModId}}\\poster"
            }
        },

        // Add movie
        {
            "Action": "EditData",
            "Target": "Data/Movies",
            "When": {
                "showmovie": "true"
            },
            "Entries": {
                "Evgen1310.ClaireFilm": {
                    "ID": "Evgen1310.ClaireFilm",
                    "Seasons": [ "{{ShowSeason}}" ],
                    "Texture": "{{ModId}}/tilesheet",
